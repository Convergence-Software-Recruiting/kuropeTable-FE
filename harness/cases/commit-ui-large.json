{
  "name": "commit-ui-large",
  "description": "대규모 UI 작업 시 커밋 분리와 메시지 규칙 점검",
  "maxCount": 15,
  "rules": {
    "messagePattern": "^(feat|fix)\\(ui\\)\\s:\\s[가-힣a-zA-Z0-9].{10,}$",
    "maxFilesChanged": 9,
    "maxInsertions": 320,
    "maxDeletions": 220,
    "maxNonUiFiles": 3,
    "ignoredPaths": [
      "package-lock.json"
    ],
    "uiPathKeywords": [
      "src/app",
      "src/components",
      "src/app/globals.css",
      "src/lib/mocks",
      "src/lib/types"
    ]
  }
}

{
  "name": "commit-unit",
  "description": "커밋 단위와 fix(ui) 메시지 컨벤션 점검",
  "maxCount": 10,
  "rules": {
    "messagePattern": "^fix\\(ui\\)\\s:\\s[가-힣a-zA-Z0-9].{10,}$",
    "maxFilesChanged": 12,
    "maxInsertions": 450,
    "maxDeletions": 350,
    "maxNonUiFiles": 4,
    "ignoredPaths": [
      "package-lock.json"
    ],
    "uiPathKeywords": [
      "src/app",
      "src/components",
      "src/app/globals.css"
    ]
  }
}
